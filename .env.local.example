# Cloud Progress Sync (Cloudflare KV)
# Setup guide: https://developers.cloudflare.com/kv/get-started/
#
# 1. Go to Cloudflare dashboard → Workers & Pages → KV
# 2. Create a namespace called "ma-progress"
# 3. Go to My Profile → API Tokens → Create Token (use "Edit Cloudflare Workers" template)
# 4. Copy your Account ID from the right sidebar on the Workers dashboard

CF_ACCOUNT_ID=your_cloudflare_account_id
CF_KV_NAMESPACE_ID=your_kv_namespace_id
CF_KV_API_TOKEN=your_api_token

# A secret string you choose — used to protect the /api/sync endpoint
# Generate one: openssl rand -hex 32
SYNC_SECRET=your_secret_here

# Also set NEXT_PUBLIC_SYNC_SECRET to the SAME value so the Settings page can send it
NEXT_PUBLIC_SYNC_SECRET=your_secret_here
